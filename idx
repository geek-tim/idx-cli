#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const os = require('os');

const HOME = os.homedir();
const CONFIG_DIR = path.join(HOME, '.config', 'idx-cli');
const CONFIG_FILE = path.join(CONFIG_DIR, 'config.json');

function loadConfig() {
  try { return JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf-8')); }
  catch { return { baseDir: path.join(HOME, 'Documents'), dirs: ['projects', 'notes', 'archives', 'inbox'] }; }
}

function saveConfig(cfg) {
  fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(cfg, null, 2));
}

let CONFIG = loadConfig();
const BASE = process.env.IDX_BASE || CONFIG.baseDir;
const DIRS = CONFIG.dirs;

const INDEX_FILE = path.join(HOME, '.local', 'share', 'idx', 'index.json');

function loadIndex() {
  try { return JSON.parse(fs.readFileSync(INDEX_FILE, 'utf-8')); }
  catch { return { version: 1, entries: [] }; }
}

function saveIndex(idx) {
  fs.mkdirSync(path.dirname(INDEX_FILE), { recursive: true });
  fs.writeFileSync(INDEX_FILE, JSON.stringify(idx, null, 2));
}

function short(p) { return p.replace(BASE + '/', '').replace(HOME + '/', ''); }

const RENDER = process.argv.includes('--render');
function out(text) {
  if (RENDER) {
    const { execSync } = require('child_process');
    try { execSync('glow', { input: text, stdio: 'inherit' }); }
    catch { console.log(text); }
  } else {
    console.log(text);
  }
}
function mdTable(headers, rows) {
  const cols = headers.length;
  const colWidths = headers.map((h, i) => Math.max(h.length, ...rows.map(r => String(r[i] || '').length)));
  const sep = '| ' + colWidths.map(w => '-'.repeat(w)).join(' | ') + ' |';
  const header = '| ' + headers.map((h, i) => h.padEnd(colWidths[i])).join(' | ') + ' |';
  const body = rows.map(r => '| ' + r.map((v, i) => String(v || '').padEnd(colWidths[i])).join(' | ') + ' |');
  return [header, sep, ...body].join('\n');
}

function usage() {
  console.log(`
Usage: idx-cli <command> [args]

Commands:
  init              Create ~/Documents/{projects,notes,archives,inbox}/
  scan [path]       Index files/directories (default: ~/Documents)
  list [--tag t]    List indexed items, filter by tag
  find <query>      Search by name or path
  tags              Show all tags with counts
  tag <query> <t1> [t2..]    Replace tags for matching items
  tag <query> --add <t1>     Add tags
  tag <query> --add <t1>     Add tags
  tag <query> --del <t1>     Remove tags
  config [key=val..]  Show or set config (baseDir, dirs)

Options:
  --render            Pipe output through glow (if installed) for rendered markdown
  IDX_BASE=path       Override base directory via env var

  -h, --help          Show this help
`);
}

// --- Commands ---

function printEntry(e) {
  return [short(e.path), e.tags.length ? e.tags.join(', ') : '-', e.type === 'dir' ? 'dir' : 'file'];
}

function cmdInit() {
  for (const d of DIRS) {
    const p = path.join(BASE, d);
    fs.mkdirSync(p, { recursive: true });
    console.log(`- ${short(p)}/`);
  }
}

function cmdScan(target) {
  const idx = loadIndex();
  const scanPath = target ? path.resolve(target) : BASE;

  if (!target) {
    const before = idx.entries.length;
    idx.entries = idx.entries.filter(e => fs.existsSync(e.path));
    if (before > idx.entries.length) console.log(`- cleaned ${before - idx.entries.length} stale entries`);
  }
  if (!fs.existsSync(scanPath)) { console.error('error: path not found'); process.exit(1); }

  const SKIP_DIRS = ['node_modules', '.git', '.next', 'dist', 'build', '.cache', '.DS_Store'];

  function shouldSkip(name, isDir) {
    return name.startsWith('.') || (isDir && SKIP_DIRS.includes(name));
  }

  const newEntries = [];
  function walk(dir, depth) {
    let items;
    try { items = fs.readdirSync(dir, { withFileTypes: true }); }
    catch { return; }
    for (const item of items) {
      if (shouldSkip(item.name, item.isDirectory())) continue;
      const full = path.join(dir, item.name);
      const existing = idx.entries.find(e => e.path === full);
      const defaultTags = [path.basename(path.dirname(full)).replace(/^_/, '')].filter(Boolean);

      if (existing) {
        existing.updated = new Date().toISOString();
        if (existing.tags.length === 0) existing.tags = defaultTags;
        newEntries.push(existing);
      } else {
        const entry = {
          path: full, name: item.name,
          type: item.isDirectory() ? 'dir' : 'file',
          tags: defaultTags,
          created: new Date().toISOString(),
          updated: new Date().toISOString(),
        };
        idx.entries.push(entry);
        newEntries.push(entry);
        console.log(`- ${short(full)}`);
      }
      if (item.isDirectory() && depth < 2) walk(full, depth + 1);
    }
  }

  walk(scanPath, 0);
  saveIndex(idx);
  console.log(`\n> ${newEntries.length} items indexed`);
}

function cmdList(filterTag) {
  const idx = loadIndex();
  let entries = idx.entries;
  if (filterTag) entries = entries.filter(e => e.tags.includes(filterTag));
  if (entries.length === 0) { out('_(no entries)_'); return; }
  out(mdTable(['Path', 'Tags', 'Type'], entries.map(e => printEntry(e))));
}

function cmdFind(query) {
  const idx = loadIndex();
  const q = query.toLowerCase();
  const entries = idx.entries.filter(e =>
    e.name.toLowerCase().includes(q) ||
    e.path.toLowerCase().includes(q) ||
    e.tags.some(t => t.toLowerCase().includes(q))
  );
  if (entries.length === 0) { out('_(no matches)_'); return; }
  out(mdTable(['Path', 'Tags', 'Type'], entries.map(e => printEntry(e))));
}

function cmdTags() {
  const idx = loadIndex();
  const tagMap = {};
  for (const e of idx.entries) {
    for (const t of e.tags) { tagMap[t] = (tagMap[t] || 0) + 1; }
  }
  const sorted = Object.entries(tagMap).sort((a, b) => b[1] - a[1]);
  if (sorted.length === 0) { out('_(no tags)_'); return; }
  out(mdTable(['Tag', 'Count'], sorted));
}

function cmdConfig(kvs) {
  if (kvs.length === 0) {
    console.log(`baseDir: ${CONFIG.baseDir}`);
    console.log(`dirs:    ${CONFIG.dirs.join(', ')}`);
    return;
  }
  for (const kv of kvs) {
    const [key, ...rest] = kv.split('=');
    const val = rest.join('=');
    if (key === 'dirs') CONFIG.dirs = val.split(',').map(s => s.trim());
    else if (key === 'baseDir') CONFIG.baseDir = val;
    else console.error(`unknown config key: ${key}`);
  }
  saveConfig(CONFIG);
  CONFIG = loadConfig();
  console.log('config updated');
}

function cmdTag(query, mode, tagArgs) {
  const idx = loadIndex();
  const q = query.toLowerCase();
  const entries = idx.entries.filter(e =>
    e.name.toLowerCase().includes(q) ||
    e.path.toLowerCase().includes(q) ||
    e.tags.some(t => t.toLowerCase().includes(q))
  );

  if (entries.length === 0) { console.error('(no matches)'); process.exit(1); }

  const lines = [];
  for (const e of entries) {
    const old = [...e.tags];
    if (mode === 'set') e.tags = [...new Set(tagArgs)];
    else if (mode === 'add') { for (const t of tagArgs) { if (!e.tags.includes(t)) e.tags.push(t); } }
    else if (mode === 'del') e.tags = e.tags.filter(t => !tagArgs.includes(t));
    lines.push(`- ${short(e.path)}: \`${old.join(', ')}\` → \`${e.tags.join(', ')}\``);
  }
  saveIndex(idx);
  console.log(lines.join('\n'));
}

// --- Main ---

const cmd = process.argv[2];
const arg1 = process.argv[3];
const arg2 = process.argv[4];
const arg3 = process.argv[5];

if (!cmd || cmd === '-h' || cmd === '--help') { usage(); process.exit(0); }

switch (cmd) {
  case 'init':
    cmdInit(); break;
  case 'scan':
    cmdScan(arg1); break;
  case 'list':
    cmdList(arg1 === '--tag' ? arg2 : null); break;
  case 'find':
    if (!arg1) { console.error('usage: idx-cli find <query>'); process.exit(1); }
    cmdFind(arg1); break;
  case 'tags':
    cmdTags(); break;
  case 'tag':
    if (!arg1 || !arg2) { console.error('usage: idx-cli tag <query> <tags...> | --add <t> | --del <t>'); process.exit(1); }
    if (arg2 === '--add') cmdTag(arg1, 'add', process.argv.slice(4));
    else if (arg2 === '--del') cmdTag(arg1, 'del', process.argv.slice(4));
    else cmdTag(arg1, 'set', process.argv.slice(3));
    break;
  case 'config':
    cmdConfig(process.argv.slice(3));
    break;
  default:
    console.error(`error: unknown command '${cmd}'`);
    usage();
    process.exit(1);
}
